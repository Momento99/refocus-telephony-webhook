{
  "name": "refocus-crm-shell",
  "private": true,
  "version": "1.1.0",
  "main": "main.js",
  "scripts": {
    "dev": "cross-env APP_URL=http://localhost:3000 CUSTOMER_PATH=/pos/customer TERMINAL=KANT-01 electron .",
    "build": "electron-builder -w nsis",
    "pack": "electron-builder -w dir"
  },
  "build": {
    "appId": "com.refocus.crm",
    "productName": "Refocus CRM",
    "directories": { "output": "dist" },
    "files": ["!node_modules/.cache/**"],
    "win": { "target": "nsis" },
    "nsis": { "oneClick": true, "createDesktopShortcut": true, "runAfterFinish": true },
    "artifactName": "RefocusCRM-Setup-${version}.exe"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  }
}
